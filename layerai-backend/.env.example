# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Google Cloud Video Intelligence
# Option 1: path to service account JSON key file (local dev)
GOOGLE_APPLICATION_CREDENTIALS=./your-service-account-key.json
# Option 2: inline JSON string of the service account key (Railway/cloud)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...",...}

# fal.ai
FAL_KEY=your-fal-api-key

# Replicate
REPLICATE_API_TOKEN=your-replicate-token

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-key

# Redis (for BullMQ job queues)
REDIS_URL=redis://localhost:6379

# Python FFmpeg Service URL
PYTHON_API_URL=http://localhost:8001

# Server
PORT=3001
NODE_ENV=development

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Optional: API Key for server-to-server auth
API_SECRET_KEY=your-secret-key
